; Unified editor settings for EllinCRM.
; https://editorconfig.org/

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

; Python follows PEP 8.
[*.{py,pyi}]
indent_size = 4
max_line_length = 100

; JSON/YAML/Markdown/TS/JS stay at the repo default (2 spaces).
[*.{json,yml,yaml,md,mdx,ts,tsx,js,jsx,cjs,mjs,css,scss}]
indent_size = 2

; Markdown: preserve meaningful trailing whitespace (two-space line breaks).
[*.{md,mdx}]
trim_trailing_whitespace = false

; Makefile and .mk require tabs.
[{Makefile,*.mk}]
indent_style = tab
